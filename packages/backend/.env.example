# Auth0 Configuration
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_API_CLIENT_ID=your-api-client-id
AUTH0_API_CLIENT_SECRET=your-api-secret
AUTH0_AUDIENCE=https://api.yourdomain.com
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com

# Federated Token Exchange (optional, defaults to true)
# Set to 'false' to use Management API instead
USE_FEDERATED_TOKEN_EXCHANGE=true

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[password]@db.bkzrwdoghjgbqezwkfkz.supabase.co:5432/postgres

# AWS Configuration (for DynamoDB refresh token storage)
AWS_REGION=us-east-1
DYNAMODB_REFRESH_TOKENS_TABLE=connected-accounts-refresh-tokens
# Storage mode: 'dynamodb' (default) or 'memory' (for local development)
REFRESH_TOKEN_STORAGE=dynamodb

# OpenAI API
OPENAI_API_KEY=sk-xxx

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS
FRONTEND_URL=http://localhost:3000
